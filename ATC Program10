#include <stdio.h>
#include <string.h>

int main() {
    char exp[100];
    int i;
    char op1, op2, op;

    printf("Enter expression (e.g., a+b): ");
    scanf("%s", exp);

    // assuming simple expression: operand operator operand
    op1 = exp[0];
    op  = exp[1];
    op2 = exp[2];

    printf("\nGenerated Assembly Code:\n");

    printf("MOV R0, %c\n", op1);

    switch(op) {
        case '+':
            printf("ADD R0, %c\n", op2);
            break;
        case '-':
            printf("SUB R0, %c\n", op2);
            break;
        case '*':
            printf("MUL R0, %c\n", op2);
            break;
        case '/':
            printf("DIV R0, %c\n", op2);
            break;
        default:
            printf("Invalid operator\n");
    }

    printf("MOV RESULT, R0\n");

    return 0;
}
