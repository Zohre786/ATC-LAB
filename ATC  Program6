#include <stdio.h>
#include <string.h>

int main() {
    char exp[100];
    int i = 0;
    char temp = 'A';  // temporary variables

    printf("Enter expression: ");
    scanf("%s", exp);

    printf("\nThree Address Code:\n");

    // Process expression from right to left
    for(i = strlen(exp) - 1; i >= 0; i--) {
        if(exp[i] == '+' || exp[i] == '-' || exp[i] == '*' || exp[i] == '/') {
            printf("%c = %c %c %c\n", temp, exp[i-1], exp[i], exp[i+1]);

            // Replace expression with temp variable
            exp[i-1] = temp;
            temp++;
        }
    }

    return 0;
}
